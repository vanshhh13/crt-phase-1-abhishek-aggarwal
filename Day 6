// find 10% -- amunt * 0.10
// discounted amount -- amount - 10% amount
  
  
  
  
#include <iostream>
using namespace std;

float discount(float discount){
    return discount -(discount * 0.10);
    
}

int main(){
    cout<< discount(5000);
}










