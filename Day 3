//problem 4
// print 1 to 10 using do- while loop

#include <iostream>
using namespace std;

int main(){
    int i=1;
    do {
        cout<<i<<"";
        i++;
    }while(i <= 10);
}





//problem 3
// print 1 to 10 using for a while loop

#include <iostream>
using namespace std;

int main(){
    int i=1;
    while(i <= 10){
        cout<< i <<" ";
        i++;
    }
}






