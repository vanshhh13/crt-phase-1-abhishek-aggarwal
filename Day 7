}






// problem 5 
// constructor overloading
#include <iostream>
using namespace std;

class rectangle {
 public:  
  int length;
  int width;

  rectangle(){
      length = 10;
      width = 20;
  }

rectangle(int l){
    length = l;
    width = 20;
}
  
  rectangle(int l, int w){
   length = l;
   width = w;
}

 void area() {
     cout << length * width;
 }
 
};

 int main (){
    rectangle r1;
    r1.area();
    rectangle r2(5);
    r2.area();
    rectangle r3(50,100);
    r3.area();
}







